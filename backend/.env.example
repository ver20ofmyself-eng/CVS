# ================================================================
#  CVS Analyzer — конфигурация окружения
#  Скопируйте этот файл в backend/.env и заполните нужные поля
# ================================================================

# ── База данных ──────────────────────────────────────────────────
# Для Docker Compose (используется внутри контейнеров):
DATABASE_URL=postgresql://cvs_user:cvs_password@postgres:5432/cvs_analyzer
# Для локальной разработки (бэкенд без Docker, БД в Docker):
LOCAL_DATABASE_URL=postgresql://cvs_user:cvs_password@localhost:5433/cvs_analyzer

# ── Безопасность ─────────────────────────────────────────────────
# ВАЖНО: обязательно замените на случайную строку в продакшене!
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_32_СИМВОЛА
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI режим ─────────────────────────────────────────────────────
# MOCK  — эмуляция (не требует API-ключа, подходит для разработки)
# REAL  — реальный DeepSeek API (требует DEEPSEEK_API_KEY)
AI_MODE=MOCK

# ── DeepSeek API ─────────────────────────────────────────────────
# Получить ключ: https://platform.deepseek.com/
# Заполните и переключите AI_MODE=REAL чтобы активировать
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
# Таймаут запроса к API в секундах
DEEPSEEK_TIMEOUT=45
# Максимум повторных попыток при сетевой ошибке (0 = без повторов)
DEEPSEEK_RETRIES=2

# ── CORS ─────────────────────────────────────────────────────────
# Для локальной разработки — разрешаем все источники:
ALLOWED_ORIGINS=["*"]
# Для продакшена замените на конкретные домены:
# ALLOWED_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]

# ── Приложение ───────────────────────────────────────────────────
APP_NAME=CVS Analyzer
APP_VERSION=2.0.0
DEBUG=false

# ── Тарифы ───────────────────────────────────────────────────────
FREE_TIER_ANALYSES=50
